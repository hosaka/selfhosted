[Unit]
Description=Caddy HTTP/2 web server
Documentation=https://caddyserver.com/docs
After=network-online.target
Wants=network-online.target systemd-networkd-wait-online.service
StartLimitIntervalSec=5
StartLimitBurst=86400

[Service]
Restart=on-failure
User={{ caddy_user }}
Group={{ caddy_user }}
Environment=CADDYPATH={{ caddy_certs_dir }}

ExecStart="{{ caddy_bin }}" run --environ --config "{{ caddy_config_path }}" {{ caddy_additional_args }}
ExecReload="{{ caddy_bin }}" reload --config "{{ caddy_config_path }}"

; max number of file descriptors, see `man systemd.exec`
LimitNOFILE=1048576

PrivateTmp=true
PrivateDevices=true
ProtectSystem=full
ReadWriteDirectories={{ caddy_certs_dir }} {{ caddy_log_dir }}
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=true

{% if caddy_environment_variables|length %}

{% for key, value in caddy_environment_variables.items() %}
Environment={{ key }}={{ value }}
{% endfor %}

{% endif %}
{% if caddy_environment_files|length %}

{% for path in caddy_environment_files %}
EnvironmentFile={{ path }}
{% endfor %}

{% endif %}
[Install]
WantedBy=multi-user.target
